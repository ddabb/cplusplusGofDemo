#pragma once

#include <iostream>
#include <memory>
#include <string>
#include <vector>

namespace design_patterns::behavioral {

class Colleague;

/**
 * @brief 抽象中介者类
 * 
 * 定义中介者的接口，声明处理同事对象通知的方法。
 */
class Mediator {
public:
    /**
     * @brief 虚析构函数
     */
    virtual ~Mediator() = default;

    /**
     * @brief 处理同事对象的通知
     * 
     * @param sender 发送消息的同事对象
     * @param message 消息内容
     */
    virtual void notify(Colleague* sender, const std::string& message) const = 0;

    /**
     * @brief 注册同事对象
     * 
     * @param colleague 同事对象
     */
    virtual void registerColleague(Colleague* colleague) = 0;
};

/**
 * @brief 抽象同事类
 * 
 * 定义同事对象的接口，声明发送和接收消息的方法。
 */
class Colleague {
protected:
    Mediator* mediator_;  ///< 中介者对象

public:
    /**
     * @brief 构造函数
     * 
     * @param mediator 中介者对象
     */
    explicit Colleague(Mediator* mediator)
        : mediator_(mediator) {
        mediator->registerColleague(this);
    }

    /**
     * @brief 虚析构函数
     */
    virtual ~Colleague() = default;

    /**
     * @brief 发送消息
     * 
     * @param message 消息内容
     */
    virtual void send(const std::string& message) = 0;

    /**
     * @brief 接收消息
     * 
     * @param message 消息内容
     */
    virtual void receive(const std::string& message) const = 0;

    /**
     * @brief 获取同事名称
     * 
     * @return std::string 同事名称
     */
    virtual std::string getName() const = 0;
};

/**
 * @brief 具体中介者类 - 聊天室
 * 
 * 实现聊天室的功能，协调所有用户之间的消息传递。
 */
class ChatRoomMediator : public Mediator {
public:
    /**
     * @brief 构造函数
     */
    ChatRoomMediator() {
        std::cout << "[ChatRoomMediator] Created" << std::endl;
    }

    /**
     * @brief 处理同事对象的通知
     * 
     * 将消息转发给所有其他同事对象。
     * 
     * @param sender 发送消息的同事对象
     * @param message 消息内容
     */
    void notify(Colleague* sender, const std::string& message) const override {
        std::cout << "[ChatRoomMediator] Broadcasting message from " << sender->getName() << std::endl;
        for (Colleague* colleague : colleagues_) {
            if (colleague != sender) {
                colleague->receive(message);
            }
        }
    }

    /**
     * @brief 注册同事对象
     * 
     * @param colleague 同事对象
     */
    void registerColleague(Colleague* colleague) override {
        colleagues_.push_back(colleague);
        std::cout << "[ChatRoomMediator] Registered: " << colleague->getName() << std::endl;
    }

    /**
     * @brief 获取注册的同事数量
     * 
     * @return size_t 同事数量
     */
    size_t getColleagueCount() const {
        return colleagues_.size();
    }

private:
    std::vector<Colleague*> colleagues_;  ///< 同事对象列表
};

/**
 * @brief 具体同事类 - 用户
 */
class User : public Colleague {
public:
    /**
     * @brief 构造函数
     * 
     * @param mediator 中介者对象
     * @param name 用户名称
     */
    User(Mediator* mediator, const std::string& name)
        : Colleague(mediator), name_(name) {
        std::cout << "[User] Created: " << name_ << std::endl;
    }

    /**
     * @brief 发送消息
     * 
     * 通过中介者发送消息给所有其他用户。
     * 
     * @param message 消息内容
     */
    void send(const std::string& message) override {
        std::cout << "[User:" << name_ << "] Sending message: \"" << message << "\"" << std::endl;
        mediator_->notify(this, "[" + name_ + "] " + message);
    }

    /**
     * @brief 接收消息
     * 
     * 显示接收到的消息。
     * 
     * @param message 消息内容
     */
    void receive(const std::string& message) const override {
        std::cout << "[User:" << name_ << "] Received message: \"" << message << "\"" << std::endl;
    }

    /**
     * @brief 获取用户名称
     * 
     * @return std::string 用户名称
     */
    std::string getName() const override {
        return name_;
    }

private:
    std::string name_;  ///< 用户名称
};

/**
 * @brief 中介者模式演示函数
 * 
 * 演示中介者模式的核心思想：用一个中介对象封装一系列的对象交互，
 * 使各对象不需要显式地相互引用，从而使其耦合松散。
 */
void mediator_demo() {
    std::cout << "\n========== Mediator Pattern Demo ==========" << std::endl;
    std::cout << "[Demo] 中介者模式核心：封装对象交互，解耦对象间引用\n" << std::endl;

    // 创建聊天室中介者
    std::cout << "[Demo] --- Creating Chat Room ---" << std::endl;
    ChatRoomMediator chatRoom;

    // 创建用户
    std::cout << "\n[Demo] --- Creating Users ---" << std::endl;
    User alice(&chatRoom, "Alice");
    User bob(&chatRoom, "Bob");
    User charlie(&chatRoom, "Charlie");

    // 用户发送消息
    std::cout << "\n[Demo] --- Chatting ---" << std::endl;
    
    alice.send("Hi everyone!");
    
    bob.send("Hello Alice!");
    
    charlie.send("Welcome to the chat room!");

    // 显示聊天室用户数量
    std::cout << "\n[Demo] --- Chat Room Info ---" << std::endl;
    std::cout << "Total users in chat room: " << chatRoom.getColleagueCount() << std::endl;

    std::cout << "\n==========================================\n" << std::endl;
}

}
